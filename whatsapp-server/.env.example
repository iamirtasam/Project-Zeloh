# Server
PORT=3001

# Log level: debug | info | warn | error
# Use 'debug' for local dev, 'info' in production
LOG_LEVEL=debug

# Test mode — compresses time for development testing
# Set TEST_MODE=false (or remove the line) before deploying to production!
# When TEST_MODE=true: 1 "day" = TEST_MODE_MINUTES real minutes
TEST_MODE=false
TEST_MODE_MINUTES=2

# Redis (AWS ElastiCache endpoint, or localhost for local dev)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_elasticache_auth_token   # uncomment when using ElastiCache

# CORS — comma-separated list of allowed browser origins (dev only)
# In production leave this empty — only Lambda calls the server directly
ALLOWED_ORIGINS=http://localhost:5173

# Resend (email OTP)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=onboarding@resend.dev

# OTP settings
OTP_TTL_SECONDS=600
MAX_WRONG_ATTEMPTS=5
BLOCK_TTL_SECONDS=1800

# Supabase (service role key — NEVER expose this in frontend)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# JWT — generate a long random secret, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# AWS S3 (for recharge screenshots and profile image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=zeloh-uploads

# Cloudflare R2 (for admin-uploaded images — movies, banners, news, etc.)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=zeloh-media
R2_PUBLIC_URL=https://cdn.zeloh.site
